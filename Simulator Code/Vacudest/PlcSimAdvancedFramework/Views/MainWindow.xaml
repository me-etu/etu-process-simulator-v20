<Window x:Class="PlcSimAdvancedFramework.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:model="clr-namespace:PlcSimAdvancedFramework.Models"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        mc:Ignorable="d"
        Title="PLCSIM Advanced Framework"
        Height="780"
        Width="1320"
        MinHeight="720"
        MinWidth="1180">
    <Window.Resources>
        <ObjectDataProvider x:Key="TagTypes" MethodName="GetValues" ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="model:TagDataType" />
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
    </Window.Resources>
    <Grid Background="#F4F1EA">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="220" />
        </Grid.RowDefinitions>

        <Border Margin="16" Padding="18" CornerRadius="12" Background="#143642">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220" />
                    <ColumnDefinition Width="180" />
                    <ColumnDefinition Width="110" />
                    <ColumnDefinition Width="110" />
                    <ColumnDefinition Width="110" />
                    <ColumnDefinition Width="110" />
                    <ColumnDefinition Width="110" />
                    <ColumnDefinition Width="130" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Instance Name" Foreground="#EDE7D9" FontWeight="SemiBold" />
                    <TextBox Margin="0,6,0,0" Padding="8,6" Text="{Binding InstanceName, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>
                <StackPanel Grid.Column="1" Margin="14,0,0,0">
                    <TextBlock Text="Project" Foreground="#EDE7D9" FontWeight="SemiBold" />
                    <TextBox Margin="0,6,0,0" Padding="8,6" Text="{Binding ProjectName, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>
                <Button Grid.Column="2" Margin="14,24,0,0" Height="34" Content="Attach" Command="{Binding AttachCommand}" />
                <Button Grid.Column="3" Margin="10,24,0,0" Height="34" Content="Power On" Command="{Binding PowerOnCommand}" />
                <Button Grid.Column="4" Margin="10,24,0,0" Height="34" Content="Power Off" Command="{Binding PowerOffCommand}" />
                <Button Grid.Column="5" Margin="10,24,0,0" Height="34" Content="Run" Command="{Binding RunCommand}" />
                <Button Grid.Column="6" Margin="10,24,0,0" Height="34" Content="Stop" Command="{Binding StopCommand}" />
                <Button Grid.Column="7" Margin="10,24,0,0" Height="34" Content="Refresh Tags" Command="{Binding RefreshTagsCommand}" />
                <StackPanel Grid.Column="8" Margin="16,0,0,0">
                    <TextBlock Text="Operating State" Foreground="#EDE7D9" FontWeight="SemiBold" />
                    <TextBlock Margin="0,8,0,0" Text="{Binding OperatingState}" FontSize="20" FontWeight="Bold" Foreground="#F7B267" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="16,0,16,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                <Button Width="110" Height="34" Content="Load Sample" Command="{Binding LoadSampleProjectCommand}" />
                <Button Width="110" Height="34" Margin="10,0,0,0" Content="Save Project" Command="{Binding SaveProjectCommand}" />
                <Button Width="110" Height="34" Margin="10,0,0,0" Content="Add Tag" Command="{Binding AddTagCommand}" />
                <Button Width="110" Height="34" Margin="10,0,0,0" Content="Remove Tag" Command="{Binding RemoveTagCommand}" />
            </StackPanel>

            <Border Grid.Row="1" CornerRadius="12" Background="#FFFDF8" BorderBrush="#D9CBB3" BorderThickness="1">
                <DataGrid ItemsSource="{Binding Tags}" SelectedItem="{Binding SelectedTag}" AutoGenerateColumns="False" CanUserAddRows="False" HeadersVisibility="Column" RowHeaderWidth="0" GridLinesVisibility="Horizontal" AlternatingRowBackground="#FFF8EE">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Display Name" Binding="{Binding DisplayName, UpdateSourceTrigger=PropertyChanged}" Width="170" />
                        <DataGridTextColumn Header="Symbolic Address" Binding="{Binding Address, UpdateSourceTrigger=PropertyChanged}" Width="210" />
                        <DataGridComboBoxColumn Header="Type" SelectedItemBinding="{Binding DataType, UpdateSourceTrigger=PropertyChanged}" ItemsSource="{Binding Source={StaticResource TagTypes}}" Width="110" />
                        <DataGridTextColumn Header="Manual Value" Binding="{Binding ManualValue, UpdateSourceTrigger=PropertyChanged}" Width="120" />
                        <DataGridCheckBoxColumn Header="Manual Enabled" Binding="{Binding ManualEnabled, UpdateSourceTrigger=PropertyChanged}" Width="110" />
                        <DataGridTextColumn Header="Last Read" Binding="{Binding LastReadValue}" IsReadOnly="True" Width="120" />
                        <DataGridTextColumn Header="Description" Binding="{Binding Description, UpdateSourceTrigger=PropertyChanged}" Width="*" />
                        <DataGridTemplateColumn Header="Read" Width="70">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="Read" Command="{Binding DataContext.ReadTagCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="{Binding}" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="Write" Width="80">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="Write" Command="{Binding DataContext.WriteTagCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="{Binding}" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>

        <Border Grid.Row="2" Margin="16,0,16,16" CornerRadius="12" Background="#1D1E2C">
            <DockPanel Margin="16">
                <TextBlock DockPanel.Dock="Top" Text="Status" Foreground="#F3F4F6" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,10" />
                <ListBox ItemsSource="{Binding StatusEntries}" Background="#1D1E2C" Foreground="#CDE7F0" BorderThickness="0" />
            </DockPanel>
        </Border>
    </Grid>
</Window>

