<Window x:Class="CoSimulationPlcSimAdv.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Icon="/CoSimulationPlcSimAdv;component/Images/CrossLink.ico"
        Title="Simulator" MinHeight="650" MinWidth="900" Width="1100" Height="760" Closing="Window_Closing" >
    <Window.Resources>
        <ResourceDictionary>
            <Style TargetType="{x:Type Button}">
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Foreground" Value="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}"/>
                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
                <Setter Property="Padding" Value="1"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type Button}">
                            <Grid>
                                <VisualStateManager.VisualStateGroups>
                                    <VisualStateGroup x:Name="CommonStates">
                                        <VisualState x:Name="Normal">
                                            <Storyboard>
                                                <ColorAnimation To="#F0F0F0" Storyboard.TargetName="BgBrush" Storyboard.TargetProperty="(GradientBrush.GradientStops)[0].(GradientStop.Color)" Duration="0:0:0.07"/>
                                                <ColorAnimation To="#E5E5E5" Storyboard.TargetName="BgBrush" Storyboard.TargetProperty="(GradientBrush.GradientStops)[1].(GradientStop.Color)" Duration="0:0:0.07"/>
                                                <ColorAnimation To="#ACACAC" Storyboard.TargetName="BrBrush" Storyboard.TargetProperty="Color" Duration="0:0:0.07" />
                                            </Storyboard>
                                        </VisualState>
                                        <VisualState x:Name="MouseOver">
                                            <Storyboard>
                                                <ColorAnimation To="#F0F4F9" Storyboard.TargetName="BgBrush" Storyboard.TargetProperty="(GradientBrush.GradientStops)[0].(GradientStop.Color)" Duration="0:0:0.07"/>
                                                <ColorAnimation To="#E0ECF9" Storyboard.TargetName="BgBrush" Storyboard.TargetProperty="(GradientBrush.GradientStops)[1].(GradientStop.Color)" Duration="0:0:0.07"/>
                                                <ColorAnimation To="#7EB4EA" Storyboard.TargetName="BrBrush" Storyboard.TargetProperty="Color" Duration="0:0:0.07" />
                                            </Storyboard>
                                        </VisualState>
                                        <VisualState x:Name="Pressed">
                                            <Storyboard>
                                                <ColorAnimation To="#DBEDFD" Storyboard.TargetName="BgBrush" Storyboard.TargetProperty="(GradientBrush.GradientStops)[0].(GradientStop.Color)" Duration="0:0:0.05"/>
                                                <ColorAnimation To="#C4E0FC" Storyboard.TargetName="BgBrush" Storyboard.TargetProperty="(GradientBrush.GradientStops)[1].(GradientStop.Color)" Duration="0:0:0.05"/>
                                                <ColorAnimation To="#569DE5" Storyboard.TargetName="BrBrush" Storyboard.TargetProperty="Color" Duration="0:0:0.05" />
                                            </Storyboard>
                                        </VisualState>
                                        <VisualState x:Name="Disabled">
                                            <Storyboard>
                                                <ColorAnimation To="#EFEFEF" Storyboard.TargetName="BgBrush" Storyboard.TargetProperty="(GradientBrush.GradientStops)[0].(GradientStop.Color)" Duration="0:0:0"/>
                                                <ColorAnimation To="#EFEFEF" Storyboard.TargetName="BgBrush" Storyboard.TargetProperty="(GradientBrush.GradientStops)[1].(GradientStop.Color)" Duration="0:0:0"/>
                                                <ColorAnimation To="#D9D9D9" Storyboard.TargetName="BrBrush" Storyboard.TargetProperty="Color" Duration="0:0:0" />
                                            </Storyboard>
                                        </VisualState>
                                    </VisualStateGroup>
                                </VisualStateManager.VisualStateGroups>
                                <Border x:Name="Chrome" BorderThickness="{TemplateBinding BorderThickness}" SnapsToDevicePixels="true">
                                    <Border.BorderBrush>
                                        <SolidColorBrush x:Name="BrBrush" Color="#ACACAC" />
                                    </Border.BorderBrush>
                                    <Border.Background>
                                        <LinearGradientBrush x:Name="BgBrush" EndPoint="0,1" StartPoint="0,0">
                                            <GradientStop Color="#F0F0F0" Offset="0"/>
                                            <GradientStop Color="#E5E5E5" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" Margin="{TemplateBinding Padding}" RecognizesAccessKey="True" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                                </Border>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsEnabled" Value="false">
                                    <Setter Property="Foreground" Value="#ADADAD"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Grid x:Name="RootGrid" Background="#FF5A6F8C">
        <Grid.RowDefinitions>
            <RowDefinition Height="23"/>
            <RowDefinition Height="36"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Menu Grid.Row="0" Background="#FF1B2030">
            <MenuItem Command="{Binding ExitCommand}"  Header="EXIT" Foreground="White">
            </MenuItem>
        </Menu>

        <DockPanel Grid.Row="1" Margin="8,6,8,6" LastChildFill="True">
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                <Button Command="{Binding PowerOnInstanceCommand}" Content="SPS ON" Width="92" Height="24" Margin="0,0,4,0"/>
                <Button Command="{Binding PowerOffInstanceCommand}" Content="SPS OFF" Width="92" Height="24" Margin="0,0,4,0"/>
                <Button Command="{Binding RunInstanceCommand}" Content="SPS RUN" Width="92" Height="24" Margin="0,0,4,0"/>
                <Button Command="{Binding StopInstanceCommand}" Content="SPS STOP" Width="92" Height="24" Margin="0,0,12,0"/>
                <Button Command="{Binding DiagnosticIoCommand}" Content="TEST IO" Width="92" Height="24" Margin="0,0,12,0"/>
                <TextBlock Text="Time Factor" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBox x:Name="TimeFactor_Setpoint" Height="22" TextWrapping="Wrap" Width="90" KeyDown="TimeFactor_Setpoint_KeyDown" Margin="0,0,12,0"/>
            </StackPanel>
            <TextBox Text="{Binding StatusPLCInstance}" x:Name="tBPLCInstance" TextAlignment="Center" Height="24"/>
        </DockPanel>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#FF4C607A" Padding="8">
                <StackPanel x:Name="UnitSidebarPanel">
                    <TextBlock Text="Units" Foreground="White" FontWeight="Bold" FontSize="14" Margin="0,0,0,8"/>
                    <Button Content="All" Tag="All" Height="28" Margin="0,0,0,6" Click="UnitSidebarButton_Click"/>
                    <Button Content="Base / Common" Tag="Base" Height="28" Margin="0,0,0,6" Click="UnitSidebarButton_Click"/>
                    <Button Content="Commissioning DB" Tag="CommissioningDb" Height="28" Margin="0,0,0,6" Click="UnitSidebarButton_Click"/>
                </StackPanel>
            </Border>

            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="8">
                    <StackPanel x:Name="BaseUnitPanel">
                <TextBlock Text="Analog Inputs" Foreground="White" FontWeight="Bold" FontSize="14" Margin="0,0,0,6"/>
                <WrapPanel Margin="0,0,0,18">
                    <StackPanel Width="132" Margin="0,0,8,8">
                        <ToggleButton x:Name="LC_4_20_8_4_ActValueButton" Content="Error" Height="24"/>
                        <ToggleButton x:Name="LC_4_20_8_4_SetpointButton" Content="Sim LC 4.20.8.4" Height="24"/>
                        <TextBox x:Name="LC_4_20_8_4_SetpointEdit" Height="22" TextWrapping="Wrap"/>
                    </StackPanel>
                    <StackPanel Width="132" Margin="0,0,8,8">
                        <ToggleButton x:Name="QC_9_1_8_4_ActValueButton" Content="Error" Height="24"/>
                        <ToggleButton x:Name="QC_9_1_8_4_SetpointButton" Content="Sim QC 9.1.8.4" Height="24"/>
                        <TextBox x:Name="QC_9_1_8_4_SetpointEdit" Height="22" TextWrapping="Wrap"/>
                    </StackPanel>
                    <StackPanel Width="132" Margin="0,0,8,8">
                        <ToggleButton x:Name="QC_10_1_8_4_ActValueButton" Content="Error" Height="24"/>
                        <ToggleButton x:Name="QC_10_1_8_4_SetpointButton" Content="Sim QC 10.1.8.4" Height="24"/>
                        <TextBox x:Name="QC_10_1_8_4_SetpointEdit" Height="22" TextWrapping="Wrap"/>
                    </StackPanel>
                    <StackPanel Width="132" Margin="0,0,8,8">
                        <ToggleButton x:Name="PS_6_1_8_4_ActValueButton" Content="Error" Height="24"/>
                        <ToggleButton x:Name="PS_6_1_8_4_SetpointButton" Content="Sim PS 6.1.8.4" Height="24"/>
                        <TextBox x:Name="PS_6_1_8_4_SetpointEdit" Height="22" TextWrapping="Wrap"/>
                    </StackPanel>
                    <StackPanel Width="132" Margin="0,0,8,8">
                        <ToggleButton x:Name="TC_5_3_31_1_ActValueButton" Content="Error" Height="24"/>
                        <ToggleButton x:Name="TC_5_3_31_1_SetpointButton" Content="Sim TC 5.3.31.1" Height="24"/>
                        <TextBox x:Name="TC_5_3_31_1_SetpointEdit" Height="22" TextWrapping="Wrap"/>
                    </StackPanel>
                    <StackPanel Width="132" Margin="0,0,8,8">
                        <ToggleButton x:Name="TI_5_10_31_1_ActValueButton" Content="Error" Height="24"/>
                        <ToggleButton x:Name="TI_5_10_31_1_SetpointButton" Content="Sim TI 5.10.31.1" Height="24"/>
                        <TextBox x:Name="TI_5_10_31_1_SetpointEdit" Height="22" TextWrapping="Wrap"/>
                    </StackPanel>
                    <StackPanel Width="132" Margin="0,0,8,8">
                        <ToggleButton x:Name="TI_5_20_31_1_ActValueButton" Content="Error" Height="24"/>
                        <ToggleButton x:Name="TI_5_20_31_1_SetpointButton" Content="Sim TI 5.20.31.1" Height="24"/>
                        <TextBox x:Name="TI_5_20_31_1_SetpointEdit" Height="22" TextWrapping="Wrap"/>
                    </StackPanel>
                    <StackPanel Width="132" Margin="0,0,8,8">
                        <ToggleButton x:Name="FI_8_1_31_1_ActValueButton" Content="Error" Height="24"/>
                        <ToggleButton x:Name="FI_8_1_31_1_SetpointButton" Content="Sim FI 8.1.31.1" Height="24"/>
                        <TextBox x:Name="FI_8_1_31_1_SetpointEdit" Height="22" TextWrapping="Wrap"/>
                    </StackPanel>
                </WrapPanel>

                <TextBlock Text="Digital Inputs" Foreground="White" FontWeight="Bold" FontSize="14" Margin="0,0,0,6"/>
                <WrapPanel Margin="0,0,0,18">
                    <ToggleButton x:Name="LSA_4_1_8_3_ActValueButton" Content="LSA 4.1.8.3" Width="132" Height="24" Margin="0,0,8,8"/>
                    <ToggleButton x:Name="FS_8_2_35_2_ActValueButton" Content="FS 8.2.35.2" Width="132" Height="24" Margin="0,0,8,8"/>
                    <ToggleButton x:Name="PS_6_3_8_4_ActValueButton" Content="PS 6.3.8.4" Width="132" Height="24" Margin="0,0,8,8"/>
                    <ToggleButton x:Name="QC_9_1_8_4_CALIB_ActValueButton" Content="QC 9.1.8.4 Calib" Width="132" Height="24" Margin="0,0,8,8"/>
                    <ToggleButton x:Name="FI_8_1_31_1_PULSE_ActValueButton" Content="FI 8.1.31.1 Pulse" Width="132" Height="24" Margin="0,0,8,8"/>
                    <ToggleButton x:Name="G21_MS_ActValueButton" Content="G21 MS" Width="132" Height="24" Margin="0,0,8,8"/>
                    <ToggleButton x:Name="G21_MPS_ActValueButton" Content="G21 MPS" Width="132" Height="24" Margin="0,0,8,8"/>
                    <ToggleButton x:Name="G31_MS_ActValueButton" Content="G31 MS" Width="132" Height="24" Margin="0,0,8,8"/>
                    <ToggleButton x:Name="G31_MPS_ActValueButton" Content="G31 MPS" Width="132" Height="24" Margin="0,0,8,8"/>
                    <ToggleButton x:Name="G41_MS_ActValueButton" Content="G41 MS" Width="132" Height="24" Margin="0,0,8,8"/>
                    <ToggleButton x:Name="G41_MPS_ActValueButton" Content="G41 MPS" Width="132" Height="24" Margin="0,0,8,8"/>
                </WrapPanel>

                <TextBlock Text="Valve Feedback" Foreground="White" FontWeight="Bold" FontSize="14" Margin="0,0,0,6"/>
                <WrapPanel>
                    <StackPanel Width="196" Margin="0,0,8,8">
                        <ToggleButton x:Name="Q21_SimFbButton" Content="Sim Q21" Height="24"/>
                        <StackPanel Orientation="Horizontal">
                            <ToggleButton x:Name="Q21_SimFbOpenButton" Content="OPEN" Width="98" Height="24"/>
                            <ToggleButton x:Name="Q21_SimFbCloseButton" Content="CLOSE" Width="98" Height="24"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <ToggleButton x:Name="Q21_QB_ErrorFbOpenButton" Content="Open QB" Width="98" Height="24"/>
                            <ToggleButton x:Name="Q21_QB_ErrorFbCloseButton" Content="Close QB" Width="98" Height="24"/>
                        </StackPanel>
                        <ToggleButton x:Name="Q21_MVCtrlButton" Content="Manual Ctrl Q21" Height="24"/>
                    </StackPanel>
                    <StackPanel Width="196" Margin="0,0,8,8">
                        <ToggleButton x:Name="Q31_SimFbButton" Content="Sim Q31" Height="24"/>
                        <StackPanel Orientation="Horizontal">
                            <ToggleButton x:Name="Q31_SimFbOpenButton" Content="OPEN" Width="98" Height="24"/>
                            <ToggleButton x:Name="Q31_SimFbCloseButton" Content="CLOSE" Width="98" Height="24"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <ToggleButton x:Name="Q31_QB_ErrorFbOpenButton" Content="Open QB" Width="98" Height="24"/>
                            <ToggleButton x:Name="Q31_QB_ErrorFbCloseButton" Content="Close QB" Width="98" Height="24"/>
                        </StackPanel>
                        <ToggleButton x:Name="Q31_MVCtrlButton" Content="Manual Ctrl Q31" Height="24"/>
                    </StackPanel>
                    <StackPanel Width="196" Margin="0,0,8,8">
                        <ToggleButton x:Name="Q41_SimFbButton" Content="Sim Q41" Height="24"/>
                        <StackPanel Orientation="Horizontal">
                            <ToggleButton x:Name="Q41_SimFbOpenButton" Content="OPEN" Width="98" Height="24"/>
                            <ToggleButton x:Name="Q41_SimFbCloseButton" Content="CLOSE" Width="98" Height="24"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <ToggleButton x:Name="Q41_QB_ErrorFbOpenButton" Content="Open QB" Width="98" Height="24"/>
                            <ToggleButton x:Name="Q41_QB_ErrorFbCloseButton" Content="Close QB" Width="98" Height="24"/>
                        </StackPanel>
                        <ToggleButton x:Name="Q41_MVCtrlButton" Content="Manual Ctrl Q41" Height="24"/>
                    </StackPanel>
                </WrapPanel>
                    </StackPanel>

                    <StackPanel x:Name="ConfiguredUnitPanels"/>

                    <StackPanel x:Name="CommissioningDbPanel" Visibility="Collapsed">
                        <DockPanel Margin="0,0,0,10">
                            <TextBlock Text="Commissioning DB" Foreground="White" FontWeight="Bold" FontSize="16" DockPanel.Dock="Left"/>
                            <Button Command="{Binding ImportCommissioningDbCommand}" Content="Import DB" Width="96" Height="24" DockPanel.Dock="Right"/>
                        </DockPanel>

                        <ItemsControl ItemsSource="{Binding CommissioningDbConfigs}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,0,0,18">
                                        <TextBlock Text="{Binding dbName}" Foreground="White" FontWeight="Bold" FontSize="14" Margin="0,0,0,6"/>
                                        <ItemsControl ItemsSource="{Binding variables}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Width="220" Margin="0,0,8,8">
                                                        <TextBlock Text="{Binding plcTag}" Foreground="White" FontSize="11"/>
                                                        <CheckBox Content="{Binding displayName}" Tag="{Binding}" Foreground="White" Checked="CommissioningBool_Checked" Unchecked="CommissioningBool_Unchecked">
                                                            <CheckBox.Style>
                                                                <Style TargetType="{x:Type CheckBox}">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding dataType}" Value="Bool">
                                                                            <Setter Property="Visibility" Value="Visible"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </CheckBox.Style>
                                                        </CheckBox>
                                                        <TextBox Text="{Binding defaultValue}" Tag="{Binding}" Height="22" KeyDown="CommissioningReal_KeyDown" LostFocus="CommissioningReal_LostFocus">
                                                            <TextBox.Style>
                                                                <Style TargetType="{x:Type TextBox}">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding dataType}" Value="Real">
                                                                            <Setter Property="Visibility" Value="Visible"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBox.Style>
                                                        </TextBox>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <StackPanel Visibility="{Binding DiagnosticProgressVisibility}" Margin="0,10,0,8">
                        <TextBlock Text="{Binding DiagnosticProgressText}" Foreground="White" FontWeight="Bold" FontSize="12" Margin="0,0,0,4"/>
                        <ProgressBar Minimum="0" Maximum="{Binding DiagnosticProgressMaximum}" Value="{Binding DiagnosticProgressValue}" Height="16"/>
                    </StackPanel>

                <TextBlock Text="Status" Foreground="White" FontWeight="Bold" FontSize="14" Margin="0,10,0,6"/>
                <ListBox ItemsSource="{Binding StatusListView}" MinHeight="120" MaxHeight="220" Background="#FFE9EEF4" BorderThickness="0"/>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>


